# ════════════════════════════════════════════════════════════════
#  SIN — Environment Variables
#  Copy this to .env and fill in your values.
#  .env is gitignored. This file (.env.example) is committed.
#
#  Variable priority in database.py:
#    SIN_DB_* (docker-compose) > POSTGRES_* (postgres service) > defaults
# ════════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────────
POSTGRES_USER=sin_user
POSTGRES_PASSWORD=change_me_before_running
POSTGRES_DB=sin_network_db

SIN_DB_BACKEND=postgres
SIN_DB_HOST=db
SIN_DB_USER=sin_user
SIN_DB_PASSWORD=change_me_before_running
SIN_DB_NAME=sin_network_db

# ── Redis ─────────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_before_running

# ── API Security ──────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SIN_API_KEY=generate_a_real_key_here

# ── Scanner ───────────────────────────────────────────────────────
SIN_SCAN_SUBNET=192.168.1
# SIN_PROTECTED_IPS=192.168.1.1,192.168.1.2

# ── Response mode ─────────────────────────────────────────────────
# observe | alert | supervised | autonomous
SIN_RESPONSE_MODE=supervised
DRY_RUN=true

# ── Notifications (all optional) ──────────────────────────────────
DISCORD_WEBHOOK_URL=
SLACK_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Enrichment APIs (all optional) ────────────────────────────────
NVD_API_KEY=
SHODAN_API_KEY=
DEEPSEEK_API_KEY=
